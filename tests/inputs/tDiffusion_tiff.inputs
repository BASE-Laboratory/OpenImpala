# Diffusion.cpp Integration Test: Full TIFF Solve
#
# Exercises the full homogenization pipeline in Diffusion.cpp:
#   - TIFF file I/O
#   - EffectiveDiffusivityHypre solve in all 3 directions
#   - D_eff tensor calculation
#   - ResultsJSON output
#   - Physics configuration (diffusion type)

filename = SampleData_2Phase_stack_3d_1bit.tif
data_path = ./data/
results_path = ./tDiffusion_tiff_results/
threshold_val = 0.5
phase_id = 1
box_size = 32
verbose = 1
dry_run = 0
write_plotfile = 0
calculation_method = homogenization
solver_type = FlexGMRES

# --- Solver Controls ---
hypre.maxiter = 500
hypre.eps = 1e-9

# --- Physics Configuration ---
physics.type = diffusion
physics.bulk_property = 1.0
