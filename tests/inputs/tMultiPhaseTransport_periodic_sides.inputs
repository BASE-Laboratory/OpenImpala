# Test: Periodic lateral BCs on uniform block
#
# Uses Periodic BCs on the lateral (side) faces instead of the default
# Neumann (zero-flux). For a uniform medium this should give the same
# result since the lateral flux is zero by symmetry.
#
# Expected: tau = (N-1)/N = 31/32 = 0.96875

domain_size = 32
box_size = 16
verbose = 2
num_phases_fill = 1
direction = X
solver = FlexGMRES

expected_tau = 0.96875
tau_tolerance = 0.001

resultsdir = ./tMultiPhaseTransport_periodic_sides_results

# --- Solver Controls ---
hypre.maxiter = 500
hypre.eps = 1e-9

# --- Multi-phase configuration ---
tortuosity.active_phases = 0
tortuosity.phase_diffusivities = 1.0
tortuosity.remspot_passes = 0

# --- Boundary condition configuration ---
bc.inlet_outlet = DirichletExternal
bc.sides = Periodic
bc.value_lo = 0.0
bc.value_hi = 1.0
