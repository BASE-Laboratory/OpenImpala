# Synthetic multi-phase transport test — Z direction
#
# Same as tMultiPhaseTransport.inputs but solving in Z direction.
# Validates directional symmetry: on a uniform domain the tortuosity
# should be identical in all directions.
#
# Expected: tau = (N-1)/N = 31/32 = 0.96875 for N=32 grid

domain_size = 32
box_size = 16
verbose = 2
num_phases_fill = 1
direction = Z
solver = FlexGMRES

expected_tau = 0.96875
tau_tolerance = 0.001

resultsdir = ./tMultiPhaseTransport_dirZ_results

hypre.maxiter = 500
hypre.eps = 1e-9

tortuosity.active_phases = 0
tortuosity.phase_diffusivities = 1.0
tortuosity.remspot_passes = 0
