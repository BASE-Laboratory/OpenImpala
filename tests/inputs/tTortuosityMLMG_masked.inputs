# TortuosityMLMG Test: Masked-porous regression case
#
# Geometry: 32^3 domain, ~60% phase 0 (active) + 40% phase 1 (masked) random
# pattern, guaranteed through-channel at the centre of the cross-section.
#
# Regression for the eps=1e-9 -> eps=1e-11 tightening: prior to v4.2.20 the
# boundary flux conservation guard (1e-4 relative) failed on this geometry
# because MLMG's relative residual is referenced to ||r_initial|| instead of
# the Dirichlet-RHS norm HYPRE uses. The test passes if MLMG returns a finite
# tortuosity in a plausible range; it fails (correctly) if the guard NaNs out.
#
# No analytical tortuosity exists for this geometry, so we range-check
# rather than equality-check. The expected band [1.1, 20.0] generously
# covers plausible values for a ~60% porosity random pattern.

domain_size = 32
box_size = 16
verbose = 2
num_phases_fill = 3
direction = X

skip_tau_value_check = 1
tau_min = 1.1
tau_max = 20.0

resultsdir = ./tTortuosityMLMG_masked_results

# Use the default mlmg.eps (1e-11) — do NOT override here. The whole point of
# this test is that the *default* tolerance is tight enough.
mlmg.maxiter = 400

tortuosity.active_phases = 0
tortuosity.phase_diffusivities = 1.0
tortuosity.remspot_passes = 0
