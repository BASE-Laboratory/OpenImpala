# Regression Benchmark: Parallel Resistance (Voigt / Arithmetic Mean Bound)
#
# Geometry:  32^3 domain, alternating single-cell layers of phase 0 (D=1.0)
#            and phase 1 (D=0.5) along the Y axis.
#            Flow direction is X, so layers are PARALLEL to flow.
#
# Analytical: Each Y-column sees uniform D within itself (either D0 or D1).
#             The potential field is linear in X for every column:
#               phi_i = i/(N-1)
#             Total flux is the sum over all columns → arithmetic mean:
#               D_a = (D0+D1)/2 = 0.75
#               D_eff = D_a * N/(N-1)    (discrete boundary correction)
#               tau   = active_VF / D_eff = (N-1) / (N * D_a)
#                     = 2*(N-1) / (N*(D0+D1))
#                     = 62 / 48 = 31/24 ≈ 1.291667
#
# Reference:  Voigt bound (arithmetic mean), standard parallel-resistance model.
#             This is the upper bound on effective diffusivity for a two-phase
#             composite (Torquato, "Random Heterogeneous Materials", Ch. 21).

domain_size = 32
box_size = 16
verbose = 2
num_phases_fill = 2
direction = X
layer_axis = Y

solver = FlexGMRES

# Expected: tau = 2*(N-1) / (N*(D0+D1)) = 62/48 = 31/24 ≈ 1.291667
expected_tau = 1.291667
tau_tolerance = 0.001

resultsdir = ./tRegressionBenchmark_parallel_results

# --- Solver Controls ---
hypre.maxiter = 500
hypre.eps = 1e-9

# --- Multi-phase configuration ---
tortuosity.active_phases = 0 1
tortuosity.phase_diffusivities = 1.0 0.5
tortuosity.remspot_passes = 0
